{
  "name": "@kanera/web",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "icons:generate": "node scripts/generate-tabler-icons.mjs",
    "prestart": "node scripts/write-build-info.mjs && pnpm icons:generate",
    "prestart:https": "node scripts/write-build-info.mjs && pnpm icons:generate",
    "start": "ng serve --port 4200 --host 0.0.0.0 --proxy-config proxy.https.conf.json",
    "start:https": "ng serve --configuration push-https --port 4200 --host 0.0.0.0 --ssl --ssl-cert ../../.certs/localhost.pem --ssl-key ../../.certs/localhost-key.pem --proxy-config proxy.https.conf.json",
    "prebuild": "node scripts/write-build-info.mjs && pnpm icons:generate",
    "build": "ng build",
    "prelint": "node scripts/write-build-info.mjs && pnpm icons:generate",
    "test": "node scripts/test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit && eslint src"
  },
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/service-worker": "^21.2.18",
    "@kanera/shared": "workspace:*",
    "@stripe/stripe-js": "^9.12.0",
    "@tabler/icons-webfont": "3.44.0",
    "@tiptap/core": "3.27.1",
    "@tiptap/extension-emoji": "3.27.1",
    "@tiptap/extension-horizontal-rule": "3.27.1",
    "@tiptap/extension-image": "3.27.1",
    "@tiptap/extension-link": "3.27.1",
    "@tiptap/extension-placeholder": "3.27.1",
    "@tiptap/extension-table": "3.27.1",
    "@tiptap/extension-table-cell": "3.27.1",
    "@tiptap/extension-table-header": "3.27.1",
    "@tiptap/extension-table-row": "3.27.1",
    "@tiptap/extension-task-item": "3.27.1",
    "@tiptap/extension-task-list": "3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@tiptap/suggestion": "3.27.1",
    "dompurify": "^3.4.12",
    "idb": "^8.0.3",
    "marked": "^18.0.6",
    "posthog-js": "^1.405.2",
    "rxjs": "~7.8.2",
    "socket.io-client": "^4.8.3",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.8.1",
    "uqr": "^0.1.3",
    "write-excel-file": "^4.1.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@types/node": "^24.13.3",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vitest": "4.1.7"
  }
}
