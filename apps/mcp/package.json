{
  "name": "@kanera/mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/http.ts",
    "start": "tsx src/http.ts",
    "stdio": "tsx src/stdio.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && eslint src --ignore-pattern 'src/**/*.itest.ts'",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:integration": "bash ../../scripts/test-mcp-integration.sh"
  },
  "dependencies": {
    "@kanera/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  }
}
