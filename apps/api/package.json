{
  "name": "@kanera/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker-index.ts",
    "dev:public-api": "tsx watch src/public-api-index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "start:migrate": "pnpm db:migrate && pnpm start",
    "start:worker": "tsx src/worker-index.ts",
    "start:public-api": "tsx src/public-api-index.ts",
    "test": "node scripts/run-unit-tests.mjs",
    "test:integration": "bash ../../scripts/test-api-integration.sh",
    "lint": "tsc -p tsconfig.json --noEmit && eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:hosted-accounts": "tsx src/scripts/seed-hosted-accounts.ts",
    "db:studio": "drizzle-kit studio",
    "email:preview": "tsx src/scripts/generate-email-previews.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/request-context": "^7.0.0",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^6.0.0",
    "@kanera/shared": "workspace:*",
    "@scalar/fastify-api-reference": "^1.59.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.11.1",
    "openapi-types": "^12",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "stripe": "^22.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/sharp": "^0.32.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  }
}
