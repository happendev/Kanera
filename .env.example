# --- API ---
# Development default; docker-compose.yml overrides this to production.
NODE_ENV=development
# Controls generated API key prefixes: kanera_live_, kanera_stg_, kanera_dev_, kanera_test_.
KANERA_ENVIRONMENT=development
API_PORT=3000
API_TRUST_PROXY=false
API_REPLICAS=2
PUBLIC_API_PORT=3001
PUBLIC_API_REPLICAS=1
WORKER_PORT=3003
MCP_PORT=3002
MCP_REPLICAS=1
WEB_ORIGIN=http://localhost:4200
KANERA_PUBLIC_API_URL=http://localhost:3001
MCP_SERVER_PUBLIC_URL=

# Public API rate limits
PUBLIC_API_RATE_LIMIT_ENABLED=true
PUBLIC_API_IP_RATE_LIMIT_PER_MINUTE=60
PUBLIC_API_FAILED_KEY_RATE_LIMIT_PER_MINUTE=10
PUBLIC_API_KEY_RATE_LIMIT_PER_MINUTE=400
PUBLIC_API_UPLOAD_RATE_LIMIT_PER_MINUTE=30
PUBLIC_API_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_API_TRUST_PROXY=false

# Per-IP brute-force throttle for /auth/* (login, signup, forgot/reset password)
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
# Controls public self-signup/new org creation. Existing organisation invite
# links can still add users when this is false.
SIGNUPS_ENABLED=true
# Require 6-digit email verification for signup, invite signup, and email changes.
# Leave false until SMTP is configured; true requires working outbound mail.
EMAIL_VERIFICATION_ENABLED=false
# Optional default outbound SMTP. Organisation admins can override SMTP in-app.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kanera
# Optional EHLO/Message-ID domain; defaults to SMTP_FROM_EMAIL's domain.
SMTP_IDENTITY_DOMAIN=
# Optional comma-separated internal recipients for plain-text signup/invite alerts.
INTERNAL_NOTIFICATION_EMAILS=
# Comma-separated platform-operator emails allowed to start cross-tenant support sessions
# (POST /auth/support-session). Each must be a real, active account. Empty disables the feature.
SUPERADMIN_EMAILS=
# Lifetime in minutes of a minted support-session token (no refresh companion; re-mint when it lapses).
SUPPORT_SESSION_TTL_MINUTES=60
# Require Cloudflare Turnstile on hosted signup/email-code requests when both are set.
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Postgres
DATABASE_URL=postgres://kanera:kanera@localhost:5433/kanera
DATABASE_SSL=false
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_BIND_PORT=5433
# Production recommendation: 20 for the API server, 5-10 for the worker.
PG_POOL_MAX=20
WORKER_PG_POOL_MAX=5

# Valkey (Redis protocol)
REDIS_URL=redis://localhost:6379/0

# Realtime websocket compression. The threshold avoids spending CPU on tiny presence/move frames.
REALTIME_WEBSOCKET_COMPRESSION_ENABLED=true
REALTIME_WEBSOCKET_COMPRESSION_THRESHOLD_BYTES=1024

# Native work such as image processing, password hashing, and crypto uses libuv.
UV_THREADPOOL_SIZE=16

# JWT
# Development-only placeholders. Replace both values with long random secrets before
# exposing any deployment outside your local machine.
JWT_SECRET=change-me-to-a-long-random-string
MEDIA_SIGNING_SECRET=change-me-to-a-separate-long-random-string
# Dedicated key for encrypting stored integration secrets; min 32 chars. Keep distinct from
# JWT_SECRET. If blank, JWT_SECRET is reused (logged as a warning) — set this in production.
SECRETS_ENCRYPTION_KEY=
JWT_ACCESS_TTL=5m
JWT_REFRESH_TTL_DAYS=10

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Dokploy / production compose ---
# Set these in Dokploy's environment tab instead of committing real values.
# WEB_ORIGIN=https://kanera.example.com
# COOKIE_DOMAIN=kanera.example.com
# COOKIE_SECURE=true
# JWT_SECRET=<openssl rand -hex 32>
# MEDIA_SIGNING_SECRET=<openssl rand -hex 32>
# SECRETS_ENCRYPTION_KEY=<openssl rand -hex 32>
# Optional deployment-wide S3-compatible storage. When all required S3 values
# are set, S3 is used for uploads before organisation-level or local storage.
# Deployment mode: self_hosted (default) or hosted.
# In hosted mode, free organisations are subject to product caps. Trial/paid orgs are unlimited.
KANERA_DEPLOYMENT_MODE=self_hosted
# ATTACHMENT_MAX_BYTES=104857600
# HOSTED_FREE_ATTACHMENT_MAX_BYTES=5242880
# HOSTED_FREE_STORAGE_QUOTA_BYTES=1073741824
# HOSTED_PAID_STORAGE_QUOTA_BYTES=214748364800
# HOSTED_PRO_PRICE_MONTHLY_CENTS=400
# HOSTED_PRO_PRICE_ANNUAL_CENTS=300
# HOSTED_FREE_MAX_WORKSPACES=1
# HOSTED_FREE_MAX_BOARDS=3
# HOSTED_FREE_MAX_ORG_MEMBERS=5
# HOSTED_FREE_MAX_ENABLED_AUTOMATIONS=1
# HOSTED_FREE_MAX_GUEST_BOARDS=2
# Length (days) of the automatic trial a new org gets on signup in hosted mode.
# When it lapses the org reverts to the free plan; no payment is required.
# HOSTED_TRIAL_DAYS=30
# Required only when KANERA_DEPLOYMENT_MODE=hosted and Stripe billing is enabled.
# STRIPE_SECRET_KEY=sk_live_...
# Publishable key (non-secret) — sent to the browser so Stripe.js can confirm seat-increase payments (3DS/SCA).
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# STRIPE_PRICE_ID_PRO_ANNUAL=price_...

UPLOADS_DIR=.data/uploads
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=auto
# S3_BUCKET=kanera
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL_PREFIX=https://cdn.example.com/kanera

# Optional GitHub App for private repository link previews (PRs, commits, repos).
# Register ONE GitHub App per deployment (hosted/staging/local each register their
# own). Set the App's Setup/Callback URL to ${WEB_ORIGIN}/settings/org and grant
# read access to Repository contents, Metadata, and Pull requests, then paste the
# App ID, slug, and generated private key (PEM, newlines escaped as \n) below.
# Leave these blank on self-hosted deployments to instead bootstrap an App in-app
# via Settings > Organisation > "Set up GitHub access". Env values take precedence.
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=kanera-dev
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Optional Docker/runtime operational alerts for startup and unhandled API errors. (Slow requests are
# logged for Loki, not webhook-alerted — aggregate latency is alerted on by Grafana's p95 rule.)
# A single Slack-compatible incoming webhook; works with Slack, Zulip's slack_incoming integration,
# Mattermost, Discord, etc. Leave empty to disable delivery. This webhook also drives Grafana's alerts
# when the monitoring stack is enabled.
OPS_ALERTS_ENABLED=true
OPS_ALERT_THROTTLE_MS=300000
# Threshold for the "slow request" warn log (shipped to Loki). Not an alert trigger.
SLOW_REQUEST_LOG_MS=1000
REALTIME_OUTBOX_POLL_MS=500
REALTIME_OUTBOX_RETENTION_DAYS=30
# Examples:
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WEBHOOK_PATH
# ALERT_WEBHOOK_URL=https://zulip.example.com/api/v1/external/slack_incoming?api_key=XXXXXXXXXXXXXXXX&stream=alerts&topic=Kanera
ALERT_WEBHOOK_URL=

# --- Monitoring / observability ---
# The app registers a Prometheus /metrics endpoint (HTTP latency, DB query latency, pg pool
# saturation, Node runtime metrics), but it fails closed unless METRICS_TOKEN is set. Generate a
# unique token for every deployment; Prometheus uses the same value when monitoring is enabled.
METRICS_ENABLED=true
# METRICS_TOKEN=<paste output of: openssl rand -hex 32>
#
# The full Grafana monitoring stack (Prometheus + Grafana + Loki + Alloy + exporters) is gated behind
# the `monitoring` Compose profile and is OFF unless you opt in. To enable it, set:
# COMPOSE_PROFILES=monitoring
# GRAFANA_ADMIN_PASSWORD=<choose a strong password>   # required when monitoring is enabled
# METRICS_TOKEN is required; Prometheus refuses to start without it.
# ALERT_WEBHOOK_URL is required so provisioned Grafana alerts always have a real destination.
# Set the project name explicitly if your deployment platform would choose a different value; Alloy
# uses it to exclude unrelated containers on a shared Docker host.
# COMPOSE_PROJECT_NAME=kanera
#
# Reach Grafana + Prometheus over the internal WireGuard VPN instead of a public domain. Set
# MONITORING_BIND_IP to the server's wg0 address (same convention as POSTGRES_BIND_IP); the UIs then
# bind to that interface only. Leave it at 127.0.0.1 for loopback-only. Never use 0.0.0.0 in production.
# MONITORING_BIND_IP=172.30.0.102
# GRAFANA_BIND_PORT=3000
# PROMETHEUS_BIND_PORT=9090
#
# Optional tuning:
# PROMETHEUS_RETENTION=30d
# Hard disk ceiling for the Prometheus TSDB; oldest blocks drop once exceeded (whichever of time/size
# is hit first). Keep it comfortably under the disk you allot to the metrics volume.
# PROMETHEUS_RETENTION_SIZE=5GB
# GRAFANA_ROOT_URL=http://172.30.0.102:3000
# POSTGRES_EXPORTER_DSN=postgresql://kanera:kanera@postgres:5432/kanera?sslmode=disable
#
# Grafana alerts reuse the ALERT_WEBHOOK_URL above (no separate config). They are delivered via
# Grafana's Slack integration, which Slack and every Slack-compatible endpoint accept.
