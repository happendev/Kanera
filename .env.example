# Minimal Docker Compose configuration.
# Copy this file to .env, replace every placeholder, then run `docker compose up -d`.
# See .env.full.example for every optional setting and its default.

# Generate URL-safe secrets with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-distinct-long-random-secret
MFA_ENCRYPTION_KEY=replace-with-a-distinct-32-character-random-secret
MEDIA_SIGNING_SECRET=replace-with-a-separate-long-random-secret

# Public browser origin and cookie policy.
WEB_ORIGIN=http://localhost:4200
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# Optional for the management portal when its hostname is outside COOKIE_DOMAIN.
# Example: COOKIE_DOMAIN=kanera.example.com with ADMIN_WEB_ORIGIN=https://kanera-admin.example.com.
ADMIN_COOKIE_DOMAIN=
